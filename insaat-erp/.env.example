# AC Grup Proje ERP — Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayıp değerleri doldurun

# Güvenlik (production'da mutlaka değiştirin)
SECRET_KEY=openssl-rand-hex-32-ile-uretilmis-deger

# Veritabanı
DATABASE_URL=postgresql+asyncpg://erp:erp_pass@postgres:5432/insaat_erp

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=erp-documents

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8081"]
